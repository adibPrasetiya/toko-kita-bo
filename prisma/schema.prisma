// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/core/lib/prisma"
}

datasource db {
  provider = "mysql"
}

model Users {
  username String @id @unique @db.VarChar(100)
  name  String @db.VarChar(200)
  email  String @unique @db.VarChar(255)
  password  String @db.VarChar(255)
  isActive Boolean @default(false)
  session Session?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@map("users")
}

model SerialNumbers {
  serialNumberId String @id @db.VarChar(255)
  clientName  String? @db.VarChar(255)
  clientPhoneNumber String? @db.VarChar(20)
  shopName String? @db.VarChar(255)
  deviceId  String? @unique @db.VarChar(255)
  isActivate Boolean @default(false)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@map("serial_numbers")
}

model Session {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         Users     @relation(fields: [userId], references: [username], onDelete: Cascade)
  refreshToken String   @unique @db.VarChar(500)
  deviceId     String   @db.VarChar(255)
  deviceName   String?  @db.VarChar(255)
  userAgent    String?  @db.Text
  ipAddress    String?  @db.VarChar(45)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("sessions")
}